{
  "manifest_version": 3,
  "name": "Google Docs Audio Downloader",
  "version": "1.0.0",
  "description": "Automatically downloads audio generated by Google Docs' Listen feature",

  "permissions": [
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "https://docs.google.com/*",
    "https://*.googleapis.com/*"
  ],

  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://docs.google.com/document/*"],
      "js": ["content/injector.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "web_accessible_resources": [
    {
      "resources": ["content/page-world.js"],
      "matches": ["https://docs.google.com/*"]
    }
  ]
}
